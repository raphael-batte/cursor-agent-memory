{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/agent-memory-session-start.sh"
      }
    ],
    "preCompact": [
      {
        "command": "./hooks/agent-memory-boundary.sh"
      }
